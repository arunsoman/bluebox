# =============================================================================
# Collaborative Steering Pipeline — Environment Variables
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://pipeline:pipeline@localhost:5432/pipeline
TIMESCALEDB_URL=postgresql+asyncpg://pipeline:pipeline@localhost:5432/pipeline

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- S3 / MinIO ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=pipeline-checkpoints
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_MODEL=gpt-4
LLM_TIMEOUT_SECONDS=30

# --- Pipeline Settings ---
MAX_REVISIONS_PER_DECISION=5
DEFAULT_AUDIT_BUDGET_MB=100
AUDIT_RETENTION_DAYS=90

# --- Application ---
DEBUG=False
