# Backend Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME=Collaborative Steering Pipeline
DEBUG=false

# Database (PostgreSQL with asyncpg)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://pipeline:pipeline@localhost:5432/pipeline
TIMESCALEDB_URL=postgresql+asyncpg://pipeline:pipeline@localhost:5432/audit

# Redis (for caching, sessions, pub/sub)
REDIS_URL=redis://localhost:6379/0

# S3/MinIO (for checkpoint storage)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=pipeline-checkpoints
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# LLM API Keys
OPENAI_API_KEY=sk-you...here
ANTHROPIC_API_KEY=sk-ant...here
DEFAULT_LLM_MODEL=gpt-4
LLM_TIMEOUT_SECONDS=30

# Ollama Cloud
OLLAMA_API_KEY=your-ollama-cloud-api-key
OLLAMA_BASE_URL=https://ollama.com/v1

# Pipeline
MAX_REVISIONS_PER_DECISION=5
DEFAULT_AUDIT_BUDGET_MB=100
AUDIT_RETENTION_DAYS=90

# CORS — comma-separated allowed origins
# For Netlify frontend: https://your-site.netlify.app
# For multiple origins: https://site1.netlify.app,https://site2.netlify.app
# For development (allow all): *
CORS_ORIGINS=*

# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:5173
