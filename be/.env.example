# Copy to .env and fill in. Loaded via pydantic-settings; every variable
# below maps to a Settings class documented next to it.

# shared_kernel/llm/connector.py LLMSettings - any pydantic-ai model id
# ("anthropic:...", "openai:...", "google-gla:..."). Swapping providers is
# just changing this string.
BLUEBOX_LLM_MODEL=anthropic:claude-sonnet-4-6

# Provider API key - name depends on BLUEBOX_LLM_MODEL's provider prefix.
# pydantic-ai reads these directly (not a BLUEBOX_-prefixed var).
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# code_generation/application/workspace_manager.py WorkspaceSettings - real
# on-disk root for generated project files. Defaults to ./.workspaces
# (relative to the working directory uvicorn is started from) if unset.
BLUEBOX_WORKSPACE_ROOT=.workspaces

# shared_kernel/infrastructure/sqlite_backend.py DBSettings - where project
# state (projects, sessions, checkpoints, advisory profiles, ...) is
# persisted. Defaults to ./.bluebox.db (relative to the working directory
# uvicorn is started from) if unset - survives `--reload` restarts, unlike
# the dict-based repositories this replaced.
BLUEBOX_DB_PATH=.bluebox.db

# interfaces/api/auth.py JWTSettings - dev-only JWT signing. Change the
# secret for anything beyond local development.
BLUEBOX_JWT_SECRET=dev-secret-change-me-32-bytes-minimum-for-hs256
BLUEBOX_JWT_ALGORITHM=HS256
BLUEBOX_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
