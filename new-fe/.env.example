# REST API base URL (doc/api_event_contract.md — all endpoints are relative to this)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket base URL (doc/api_event_contract.md §1.1 — wss://api/v1/steering/session/{session_id})
# Use ws:// for plain local dev, wss:// in production.
VITE_WS_BASE_URL=ws://localhost:8000

# Idle re-auth window in minutes (PRD NF-SC-05, default 60)
VITE_SESSION_REAUTH_IDLE_MINUTES=60
