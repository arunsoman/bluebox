{
  "name": "bluebox",
  "private": true,
  "version": "1.0.0",
  "description": "Bluebox — Collaborative Steering Pipeline. Monorepo with React frontend and Python FastAPI backend.",
  "scripts": {
    "dev:fe": "cd frontend && npm run dev",
    "dev:be": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build:fe": "cd frontend && npm run build",
    "build": "npm run build:fe",
    "lint:fe": "cd frontend && npm run lint",
    "preview:fe": "cd frontend && npm run preview",
    "install:fe": "cd frontend && npm install",
    "install:be": "cd backend && pip install -r requirements.txt",
    "setup": "npm run install:fe && npm run install:be",
    "test:be": "cd backend && pytest",
    "db:migrate": "cd backend && alembic upgrade head",
    "db:generate": "cd backend && alembic revision --autogenerate",
    "docker:up": "cd backend && docker-compose up -d",
    "docker:down": "cd backend && docker-compose down",
    "docker:logs": "cd backend && docker-compose logs -f",
    "deploy:netlify": "cd frontend && npm run build && netlify deploy --prod --dir=dist"
  },
  "workspaces": [
    "frontend"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
