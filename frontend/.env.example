# Frontend Environment Variables
# Copy this file to .env and fill in your values
# All variables prefixed with VITE_ are exposed to the browser

# Backend API URL (required for production)
# For Netlify: set this to your deployed backend URL
# For local development: use localhost:8000
VITE_API_URL=http://localhost:8000

# WebSocket URL (optional — falls back to VITE_API_URL with ws:// scheme)
VITE_WS_URL=ws://localhost:8000

# Enable real WebSocket connection (default: false = mock mode)
# Set to 'true' when you have a backend running
VITE_LIVE_WS=false

# Enable real API calls (default: false = mock data)
VITE_LIVE_API=false

# Debug mode — shows extra panels and logging
VITE_DEBUG=false
