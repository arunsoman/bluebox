# Frontend Environment Variables
# All variables prefixed with VITE_ are exposed to the browser
#
# DEFAULT MODE: LIVE (connects to real backend)
# To use mock data instead, set VITE_LIVE_API=false

# Backend API URL (required for production)
# For Netlify: set this to your deployed backend URL
# For local development: use localhost:8000
VITE_API_URL=http://localhost:8000

# WebSocket URL (optional — falls back to VITE_API_URL with ws:// scheme)
VITE_WS_URL=ws://localhost:8000

# Live API mode (default: true — set to 'false' to use mock/demo data)
VITE_LIVE_API=true

# Live WebSocket mode (default: true — set to 'false' for mock WebSocket)
VITE_LIVE_WS=true

# Debug mode — shows extra panels and logging (default: false)
VITE_DEBUG=false

# ─── To use mock data (no backend needed) ───
# Uncomment the lines below:
# VITE_LIVE_API=false
# VITE_LIVE_WS=false
