{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Python File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        },
         {
      "name": "bluebox: Uvicorn API",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/be/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "bluebox.interfaces.api.app:create_app",
        "--factory",
        "--reload",
        "--port",
        "8000"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    }
    ]
}